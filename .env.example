APP_NAME=OnRamp STT API
APP_VERSION=0.1.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/onramp_stt
REDIS_URL=redis://localhost:6380/0

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data
STORAGE_BUCKET=onramp-stt
STORAGE_ENDPOINT_URL=
STORAGE_REGION=ap-northeast-2
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
STT_MAX_UPLOAD_BYTES=2147483648
STT_MAX_AUDIO_DURATION_SEC=14400

STT_VAD_AGGRESSIVENESS=1
STT_VAD_FRAME_MS=30
STT_VAD_PADDING_MS=500
STT_VAD_TRIGGER_RATIO=0.8
STT_VAD_MAX_CHUNK_SECONDS=55
STT_VAD_GAP_MS=250

NAVER_CLOVA_SPEECH_INVOKE_URL=
NAVER_CLOVA_SPEECH_SECRET_KEY=
CLOVA_REQUEST_TIMEOUT_SEC=180
CLOVA_MAX_CONCURRENT_JOBS=2
CLOVA_MAX_RETRY_COUNT=3
CLOVA_BACKOFF_BASE_SEC=2
CLOVA_BACKOFF_MAX_SEC=60
CLOVA_SEMAPHORE_LEASE_SEC=240

REDIS_STREAM_BLOCK_MS=5000
REDIS_STREAM_READ_COUNT=10
REDIS_PENDING_RECLAIM_IDLE_MS=300000

